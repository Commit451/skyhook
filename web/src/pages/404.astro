---
import '../styles/global.css'

const base = import.meta.env.BASE_URL
const year = new Date().getFullYear()
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Page not found — skyhook</title>
        <meta
            name="description"
            content="That URL does not point to a skyhook page or webhook endpoint. Return home to generate a valid skyhook URL."
        />
        <meta name="robots" content="noindex, nofollow" />
        <meta name="theme-color" content="#111114" />
        <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    </head>
    <body class="not-found-page">
        <header class="not-found-header">
            <a class="brand" href="/" aria-label="skyhook home">
                <img src={`${base}images/skyhook.png`} alt="" width="30" height="30" />
                <span class="wordmark">skyhook</span>
            </a>
            <nav aria-label="Page not found navigation">
                <a class="header-link" href="/">Home</a>
                <a
                    class="github-link"
                    href="https://github.com/Commit451/skyhook"
                    aria-label="Source on GitHub"
                    target="_blank"
                    rel="noopener"
                >
                    <svg width="21" height="21" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path
                            d="M12 .5C5.73.5.65 5.58.65 11.85c0 5.02 3.25 9.27 7.76 10.77.57.1.78-.25.78-.55v-1.93c-3.16.69-3.83-1.52-3.83-1.52-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.69.08-.69 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.52-2.52-.29-5.17-1.26-5.17-5.6 0-1.24.45-2.25 1.18-3.05-.12-.29-.51-1.45.11-3.02 0 0 .96-.3 3.14 1.17a10.94 10.94 0 0 1 5.72 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.57.23 2.73.11 3.02.74.8 1.18 1.81 1.18 3.05 0 4.36-2.65 5.31-5.18 5.59.41.36.78 1.06.78 2.15v3.19c0 .31.21.66.79.55 4.5-1.5 7.75-5.75 7.75-10.77C23.35 5.58 18.27.5 12 .5z"
                        ></path>
                    </svg>
                </a>
            </nav>
        </header>

        <main>
            <section class="not-found-copy" aria-labelledby="not-found-title">
                <p class="eyebrow">404 · route not found</p>
                <h1 id="not-found-title">This hook didn't catch anything.</h1>
                <p class="summary">
                    No skyhook page or endpoint lives at <code id="missing-path">this address</code>. Check the URL, or
                    head home to generate a valid webhook endpoint.
                </p>
                <div class="actions">
                    <a class="btn btn-primary" href="/">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M19 12H5m6-6-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                        Back to skyhook
                    </a>
                    <a class="btn btn-ghost" href="/#generate">Generate a webhook URL</a>
                </div>
                <p class="help">
                    Think this route should exist?
                    <a href="https://github.com/Commit451/skyhook/issues" target="_blank" rel="noopener">Open an issue</a>.
                </p>
            </section>

            <div class="route-card" aria-hidden="true">
                <div class="route-card-bar">
                    <span></span><span></span><span></span>
                    <span class="route-card-label">skyhook route check</span>
                </div>
                <div class="route-card-body">
                    <div class="request-node">
                        <span class="node-label">Incoming request</span>
                        <code id="route-preview">/unknown</code>
                    </div>

                    <svg class="route-line" viewBox="0 0 420 190" fill="none" preserveAspectRatio="none">
                        <path class="route-line-base" d="M10 94C88 94 97 35 173 35s76 120 154 120c43 0 61-24 83-61"></path>
                        <path class="route-line-active" d="M10 94C88 94 97 35 173 35s76 120 154 120c43 0 61-24 83-61"></path>
                    </svg>

                    <div class="hook-node">
                        <span class="logo-ring">
                            <img src={`${base}images/skyhook.png`} alt="" width="82" height="82" />
                        </span>
                    </div>

                    <div class="miss-node">
                        <span class="miss-code">404</span>
                        <span>No matching route</span>
                    </div>
                </div>
            </div>
        </main>

        <footer class="not-found-footer">
            <span>© {year} Commit451</span>
            <span aria-hidden="true">·</span>
            <span>skyhook is free and open source</span>
        </footer>

        <script is:inline>
            const path = window.location.pathname
            const missingPath = document.getElementById('missing-path')
            const routePreview = document.getElementById('route-preview')
            if (missingPath) missingPath.textContent = path
            if (routePreview) routePreview.textContent = path
        </script>
    </body>
</html>

<style>
    .not-found-page {
        display: grid;
        grid-template-rows: auto 1fr auto;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .not-found-header {
        position: relative;
    }

    .not-found-header nav {
        gap: 8px;
    }

    .not-found-header nav .header-link {
        width: auto;
        padding: 0 12px;
        border-radius: 8px;
        color: var(--on-surface-muted);
        font-size: 0.92rem;
        font-weight: 600;
    }

    .not-found-header nav .github-link {
        width: 40px;
    }

    main {
        width: min(1120px, 100%);
        margin: 0 auto;
        padding: clamp(56px, 9vw, 112px) 24px;
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
        gap: clamp(48px, 7vw, 88px);
        align-items: center;
    }

    .not-found-copy,
    .route-card {
        min-width: 0;
    }

    .not-found-copy {
        max-width: 610px;
    }

    h1 {
        max-width: 620px;
        margin: 0 0 24px;
        font-size: clamp(2.8rem, 6vw, 5.2rem);
        font-weight: 800;
        letter-spacing: -0.045em;
        line-height: 0.98;
        text-wrap: balance;
    }

    .summary {
        max-width: 58ch;
        margin: 0;
        color: var(--on-surface-muted);
        font-size: clamp(1.02rem, 2vw, 1.16rem);
        line-height: 1.75;
    }

    .summary code {
        display: inline-block;
        max-width: min(100%, 32ch);
        padding: 1px 7px;
        overflow: hidden;
        vertical-align: -0.25em;
        color: var(--primary-bright);
        background: color-mix(in srgb, var(--primary) 13%, var(--surface));
        border: 1px solid color-mix(in srgb, var(--primary) 24%, var(--border));
        border-radius: 6px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.88em;
        line-height: 1.5;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 34px;
    }

    .help {
        margin: 24px 0 0;
        color: var(--on-surface-faint);
        font-size: 0.9rem;
    }

    .help a {
        font-weight: 600;
    }

    .route-card {
        position: relative;
        min-height: 450px;
        overflow: hidden;
        background: var(--bg-elevated);
        border: 1px solid var(--border-strong);
        border-radius: 20px;
        box-shadow: 0 32px 70px -35px rgba(0, 0, 0, 0.85);
    }

    .route-card::after {
        position: absolute;
        right: -90px;
        bottom: -100px;
        width: 280px;
        height: 280px;
        background: radial-gradient(circle, rgba(0, 168, 150, 0.14), transparent 68%);
        content: '';
        pointer-events: none;
    }

    .route-card-bar {
        height: 48px;
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 0 16px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
    }

    .route-card-bar > span:not(.route-card-label) {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border-strong);
    }

    .route-card-label {
        margin-left: 8px;
        color: var(--on-surface-faint);
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.72rem;
        letter-spacing: 0.02em;
    }

    .route-card-body {
        position: relative;
        height: 402px;
    }

    .request-node,
    .miss-node {
        position: absolute;
        z-index: 3;
        display: flex;
        flex-direction: column;
        padding: 12px 14px;
        background: var(--surface);
        border: 1px solid var(--border-strong);
        border-radius: 10px;
    }

    .request-node {
        top: 56px;
        left: 34px;
        width: min(210px, calc(100% - 68px));
    }

    .node-label {
        margin-bottom: 4px;
        color: var(--on-surface-faint);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
    }

    .request-node code {
        overflow: hidden;
        color: var(--on-surface);
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.82rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .hook-node {
        position: absolute;
        z-index: 4;
        top: 151px;
        left: 50%;
        transform: translateX(-50%);
    }

    .logo-ring {
        width: 116px;
        height: 116px;
        display: grid;
        place-items: center;
        background: var(--bg);
        border: 1px solid color-mix(in srgb, var(--primary) 42%, var(--border));
        border-radius: 50%;
        box-shadow: 0 0 0 10px rgba(0, 168, 150, 0.06), 0 0 42px rgba(0, 168, 150, 0.16);
    }

    .logo-ring img {
        width: 82px;
        height: 82px;
        object-fit: contain;
    }

    .miss-node {
        right: 34px;
        bottom: 42px;
        min-width: 158px;
        border-color: color-mix(in srgb, var(--error) 38%, var(--border));
    }

    .miss-node span:last-child {
        color: var(--on-surface-muted);
        font-size: 0.78rem;
    }

    .miss-code {
        color: var(--error);
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 1.35rem;
        font-weight: 800;
        line-height: 1.1;
    }

    .route-line {
        position: absolute;
        z-index: 1;
        top: 93px;
        left: 7%;
        width: 86%;
        height: 190px;
        overflow: visible;
    }

    .route-line-base,
    .route-line-active {
        vector-effect: non-scaling-stroke;
        fill: none;
        stroke-linecap: round;
        stroke-width: 2;
    }

    .route-line-base {
        stroke: var(--border-strong);
        stroke-dasharray: 5 8;
    }

    .route-line-active {
        stroke: var(--primary);
        stroke-dasharray: 3 18;
        animation: route-pulse 2.8s linear infinite;
    }

    .not-found-footer {
        min-height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        padding: 20px 24px;
        color: var(--on-surface-faint);
        border-top: 1px solid var(--border);
        font-size: 0.86rem;
        text-align: center;
    }

    @keyframes route-pulse {
        to {
            stroke-dashoffset: -42;
        }
    }

    @media (max-width: 900px) {
        main {
            grid-template-columns: minmax(0, 1fr);
            padding-top: 64px;
        }

        .not-found-copy {
            max-width: 680px;
        }

        .route-card {
            min-height: 390px;
        }

        .route-card-body {
            height: 342px;
        }

        .hook-node {
            top: 122px;
        }

        .miss-node {
            bottom: 28px;
        }

        .route-line {
            top: 66px;
        }
    }

    @media (max-width: 560px) {
        .not-found-header {
            padding-inline: 18px;
        }

        .not-found-header nav .header-link {
            display: none;
        }

        main {
            padding: 50px 18px 56px;
            gap: 42px;
        }

        h1 {
            font-size: clamp(2.65rem, 14vw, 4rem);
        }

        .actions {
            flex-direction: column;
        }

        .actions .btn {
            width: 100%;
            min-height: 48px;
        }

        .route-card {
            min-height: 350px;
        }

        .route-card-body {
            height: 302px;
        }

        .request-node {
            top: 34px;
            left: 20px;
            width: calc(100% - 40px);
        }

        .hook-node {
            top: 110px;
            left: 32%;
        }

        .logo-ring {
            width: 94px;
            height: 94px;
        }

        .logo-ring img {
            width: 66px;
            height: 66px;
        }

        .miss-node {
            right: 20px;
            bottom: 22px;
            min-width: 148px;
        }

        .route-line {
            top: 58px;
            left: 3%;
            width: 94%;
            height: 170px;
        }

        .not-found-footer {
            flex-wrap: wrap;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .route-line-active {
            animation: none;
        }
    }
</style>
